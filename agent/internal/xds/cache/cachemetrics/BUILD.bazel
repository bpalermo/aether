load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "cachemetrics",
    srcs = ["cachemetrics.go"],
    importpath = "github.com/bpalermo/aether/agent/internal/xds/cache/cachemetrics",
    visibility = ["//agent:__subpackages__"],
    deps = ["@io_opentelemetry_go_otel_metric//:metric"],
)

go_test(
    name = "cachemetrics_test",
    srcs = ["cachemetrics_test.go"],
    embed = [":cachemetrics"],
    deps = [
        "@io_opentelemetry_go_otel_sdk_metric//:metric",
        "@io_opentelemetry_go_otel_sdk_metric//metricdata",
    ],
)
