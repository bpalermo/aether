    importpath = "github.com/bpalermo/aether/agent/internal/proxy/hotrestart",
    visibility = ["//agent:__subpackages__"],
    deps = [
        "@com_github_fsnotify_fsnotify//:fsnotify",
        "@com_github_go_logr_logr//:logr",
