load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "cmd",
    srcs = [
        "config.go",
        "root.go",
    ],
    importpath = "github.com/bpalermo/aether/agent/internal/cmd",
    visibility = ["//visibility:public"],
    deps = [
        "//agent/constants",
        "//agent/internal/cni/server",
        "//agent/internal/spire",
        "//agent/internal/xds/cache",
        "//agent/internal/xds/server",
        "//agent/storage",
        "//api/aether/cni/v1:cni",
        "//common/must",
        "//common/spire",
        "//log",
        "//registry",
        "//telemetry",
        "@com_github_go_logr_logr//:logr",
        "@com_github_spf13_cobra//:cobra",
        "@io_k8s_sigs_controller_runtime//:controller-runtime",
        "@io_k8s_sigs_controller_runtime//pkg/healthz",
        "@org_golang_google_grpc//:grpc",
        "@org_golang_google_grpc//credentials",
    ],
)

go_test(
    name = "cmd_test",
    srcs = ["config_test.go"],
    embed = [":cmd"],
    deps = [
        "//agent/constants",
        "//agent/internal/cni/server",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
    ],
)
