    visibility = ["//visibility:public"],
    deps = [
        "//agent/constants",
        "//agent/internal/cni/server",
        "//agent/internal/edge",
        "//agent/internal/edge/secret",
        "//agent/internal/node",
        "//agent/internal/proxy/hotrestart",
        "//agent/internal/spire",
        "//agent/internal/xds/ack",
        "//agent/internal/xds/cache",
        "//agent/internal/xds/proxy",
        "//agent/internal/xds/server",
        "//agent/storage",
        "//api/aether/cni/v1:cni",
        "//api/aether/config/v1:config",
        "//common/apis/config/v1:config",
        "//common/config",
        "//common/constants",
        "//common/manager",
        "//common/must",
        "//common/spire",
        "//registry",
        "@com_github_spf13_cobra//:cobra",
        "@io_k8s_api//core/v1:core",
