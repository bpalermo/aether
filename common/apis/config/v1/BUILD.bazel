    importpath = "github.com/bpalermo/aether/common/apis/config/v1",
    visibility = ["//visibility:public"],
    deps = [
        "//api/aether/config/v1:config",
        "@io_k8s_apimachinery//pkg/apis/meta/v1:meta",
