go_test(
    name = "config_test",
    srcs = ["edgeroute_test.go"],
    embed = [":config"],
    deps = [
        "//api/aether/config/v1:config",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
    ],
