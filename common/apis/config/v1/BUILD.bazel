load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "config",
    srcs = [
        "edgeroute_deepcopy.go",
        "edgeroute_jsonshim.go",
        "edgeroute_types.go",
        "meshconfig_deepcopy.go",
        "meshconfig_jsonshim.go",
        "meshconfig_types.go",
